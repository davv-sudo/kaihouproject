---
import "../styles/global.css";

interface Props {
    title: string;
}

const { title } = Astro.props;

const path = Astro.url.pathname;
const pathWithoutLocale = path.replace(/^\/(fr|es)/, "") || "/";

const currentLocale = path.startsWith("/fr")
    ? "fr"
    : path.startsWith("/es")
      ? "es"
      : "en";
const prefix = currentLocale === "en" ? "" : `/${currentLocale}`;

const langLinks = {
    en: pathWithoutLocale,
    fr: `/fr${pathWithoutLocale === "/" ? "" : pathWithoutLocale}`,
    es: `/es${pathWithoutLocale === "/" ? "" : pathWithoutLocale}`,
};
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title} · Kaihou Project</title>
    </head>
    <body>
        <nav>
            <a href="/" class="brand">Kaihou Project</a>
            <div class="nav-links">
                <a href={`${prefix}/`}>Home</a>
                <a href={`${prefix}/about`}>About</a>
                <a href={`${prefix}/services`}>Services</a>
                <a href={`${prefix}/team`}>Team</a>
                <a href={`${prefix}/partners`}>Partners</a>
                <a href={`${prefix}/blog`}>Blog</a>
                <a href={`${prefix}/faq`}>FAQ</a>
                <a href={`${prefix}/contact`}>Contact</a>
            </div>
            <div class="lang-switch">
                <a href={langLinks.en}>EN</a> | <a href={langLinks.fr}>FR</a> | <a
                    href={langLinks.es}>ES</a
                >
            </div>
        </nav>

        <main class="container" style="flex: 1;">
            <slot />
        </main>

        <footer>
            <p>&copy; 2026 Kaihou Project. All rights reserved.</p>
            <div class="socials">
                <a href="#" aria-label="Discord">Discord</a>
                <a href="#" aria-label="YouTube">YouTube</a>
                <a href="#" aria-label="Twitch">Twitch</a>
                <a href="#" aria-label="LinkedIn">LinkedIn</a>
            </div>
        </footer>

        <script type="text/javascript">
            var Tawk_API = Tawk_API || {},
                Tawk_LoadStart = new Date();
            (function () {
                var s1 = document.createElement("script"),
                    s0 = document.getElementsByTagName("script")[0];
                s1.async = true;
                s1.src =
                    "https://embed.tawk.to/6665b6cd9a809f19fb3bc7ac/1hvul45ek";
                s1.charset = "UTF-8";
                s1.setAttribute("crossorigin", "*");
                s0.parentNode.insertBefore(s1, s0);
            })();
        </script>
    </body>
</html>

<style>
    nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 2rem;
        border-bottom: 1px solid var(--border);
    }
    .brand {
        font-weight: bold;
        font-size: 1.25rem;
    }
    .nav-links {
        display: flex;
        gap: 1.5rem;
    }
    footer {
        border-top: 1px solid var(--border);
        padding: 2rem;
        text-align: center;
    }
    .socials {
        display: flex;
        justify-content: center;
        gap: 1rem;
        margin-top: 1rem;
    }
</style>
