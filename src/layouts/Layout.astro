---
import "../styles/global.css";

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title} · Kaihou Project</title>
    </head>
    <body>
        <nav>
            <a href="/" class="brand">Kaihou Project</a>
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/about">About</a>
                <a href="/services">Services</a>
                <a href="/team">Team</a>
                <a href="/partners">Partners</a>
                <a href="/blog">Blog</a>
                <a href="/faq">FAQ</a>
                <a href="/contact">Contact</a>
            </div>
            <div class="lang-switch">
                <a href="/">EN</a> | <a href="/fr/">FR</a> | <a href="/es/"
                    >ES</a
                >
            </div>
        </nav>

        <main class="container" style="flex: 1;">
            <slot />
        </main>

        <footer>
            <p>&copy; 2026 Kaihou Project. All rights reserved.</p>
            <div class="socials">
                <a href="#" aria-label="Discord">Discord</a>
                <a href="#" aria-label="YouTube">YouTube</a>
                <a href="#" aria-label="Twitch">Twitch</a>
                <a href="#" aria-label="LinkedIn">LinkedIn</a>
            </div>
        </footer>

        <script type="text/javascript">
            var Tawk_API = Tawk_API || {},
                Tawk_LoadStart = new Date();
            (function () {
                var s1 = document.createElement("script"),
                    s0 = document.getElementsByTagName("script")[0];
                s1.async = true;
                s1.src =
                    "https://embed.tawk.to/6665b6cd9a809f19fb3bc7ac/1hvul45ek";
                s1.charset = "UTF-8";
                s1.setAttribute("crossorigin", "*");
                s0.parentNode.insertBefore(s1, s0);
            })();
        </script>
    </body>
</html>

<style>
    nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 2rem;
        border-bottom: 1px solid var(--border);
    }
    .brand {
        font-weight: bold;
        font-size: 1.25rem;
    }
    .nav-links {
        display: flex;
        gap: 1.5rem;
    }
    footer {
        border-top: 1px solid var(--border);
        padding: 2rem;
        text-align: center;
    }
    .socials {
        display: flex;
        justify-content: center;
        gap: 1rem;
        margin-top: 1rem;
    }
</style>
